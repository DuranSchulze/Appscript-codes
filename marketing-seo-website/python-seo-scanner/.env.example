# SEO Scanner Environment Configuration

# AI Provider API Keys (at least one required for keyword recommendations)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Default AI provider to use (gemini or openai)
DEFAULT_AI_PROVIDER=gemini

# Google API Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Enable APIs: Search Console API, Analytics Data API
GSC_PROPERTY=https://example.com/
GA4_PROPERTY_ID=123456789

# Google Ads API Configuration
# Get from Google Ads API Center: https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_manager_account_id_optional
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_optional

# SEMrush API Configuration (alternative to Google Ads)
# Get from SEMrush API Management: https://www.semrush.com/api-management/
SEMRUSH_API_KEY=your_semrush_api_key_here
DEFAULT_MAX_PAGES=100
DEFAULT_MAX_DEPTH=2
DEFAULT_CRAWL_DELAY=0.5
